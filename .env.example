# Copia este archivo a .env y llena tus propios valores.
# NUNCA subas el .env real a git -- por eso esta en .gitignore.

SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Si no la defines, el proyecto usa sqlite local automaticamente.
# En EC2 (produccion), usar la URL real de Postgres:
# DATABASE_URL=postgres://usuario:password@localhost:5432/gavi_crm
DATABASE_URL=

# Igual con Redis -- si no la defines, usa localhost:6379 por defecto.
REDIS_URL=redis://127.0.0.1:6379/1

# Twilio WhatsApp (dejar vacio hasta recibir las cuentas de GAVI).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# URL publica exacta que Twilio usara, sin slash final. Ej.: https://crm.gaviperu.com
TWILIO_WEBHOOK_BASE_URL=
